# IDA Pro install directory. Required.
# Example: /opt/ida-pro-9.3 or /home/ubuntu/idapro-9.0
IDA_INSTALL_DIR=/opt/ida-pro-9.3

# DEPRECATED legacy env. If IDA_INSTALL_DIR is unset but IDA_PATH is set,
# the server infers IDA_INSTALL_DIR = dirname(IDA_PATH) and emits a
# deprecation warning. New deployments should set IDA_INSTALL_DIR directly.
# IDA_PATH=/home/ubuntu/idapro-9.0/idat

# Path to an IDB file to auto-load at startup. Optional.
# When empty, the agent must call the `set_binary_path` MCP tool before use.
IDB_PATH=

# Colon-separated plugin paths injected at sys.path[0] after idalib bootstrap.
# Empty / unset = no plugin injection. Examples:
#   IDA_MCP_PLUGIN_PATHS=/path/to/your-plugin
#   IDA_MCP_PLUGIN_PATHS=/path/to/plugin-a:/path/to/plugin-b
IDA_MCP_PLUGIN_PATHS=

# MCP server listen port. Optional, default 8888.
PORT=8888

# MCP server listen host. Optional, default 0.0.0.0.
HOST=0.0.0.0

# MCP transport: sse or stdio. Optional, default sse.
TRANSPORT=sse
# TRANSPORT=stdio
